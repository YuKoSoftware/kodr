module net

// net — TCP networking for Orhon programs
// Import with: import std::net

// ── TCP Client ──

// Connect to a TCP server

pub bridge func tcpConnect(host: String, port: i32) ErrorUnion(Connection)

// ── TCP Server ──

// Listen for TCP connections on a port

pub bridge func tcpListen(host: String, port: i32) ErrorUnion(Listener)

// ── Connection ──

pub bridge struct Connection {

    // Send data over the connection

    bridge func send(self: mut& Connection, data: String) ErrorUnion(void)

    // Receive up to n bytes

    bridge func recv(self: mut& Connection, n: i32) ErrorUnion(String)

    // Close the connection

    bridge func close(self: mut& Connection) void
}

// ── Listener ──

pub bridge struct Listener {

    // Accept a new connection (blocks until one arrives)

    bridge func accept(self: mut& Listener) ErrorUnion(Connection)

    // Stop listening

    bridge func close(self: mut& Listener) void
}
