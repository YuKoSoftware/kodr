module collections

// collections — generic data structures for Orhon programs
// Import with: use std::collections (or import std::collections)
// Types are generic constructors: List(i32), Map(String, i32), Set(String)

// List(T) — dynamic array

pub bridge func List(T: type) type

// Map(K, V) — hash map

pub bridge func Map(K: type, V: type) type

// Set(T) — hash set

pub bridge func Set(T: type) type
