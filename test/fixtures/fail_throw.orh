module fixture

#version = (1, 0, 0)
#build   = exe

func may_fail(n: i32) (Error | i32) {
    if(n == 0) {
        return Error("bad")
    }
    return n
}

// throw in void function -- should produce compile error
func void_throw() void {
    var result = may_fail(1)
    throw result
}

func main() void { }
