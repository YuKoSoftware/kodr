module main

#name    = "fail_borrow"
#version = Version(1, 0, 0)
#build   = exe

struct Point {
    pub x: i32
    pub y: i32
}

// cannot borrow as mutable while immutably borrowed

func borrow_conflict() void {
    var p: Point = Point(x: 1, y: 2)
    const r1: const &Point = &p
    const r2: &Point = &p
}

// use while mutably borrowed suggests const &

func use_while_borrowed() void {
    var q: Point = Point(x: 3, y: 4)
    const r: &Point = &q
    const _ = q
}

func main() void { }
