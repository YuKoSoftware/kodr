module fail_return_ref


struct Point {
    pub x: i32
    pub y: i32
}

func return_mut_ref() mut& Point {
    var p: Point = Point{x: 1, y: 2}
    return mut& p  //> [E3003]
}

func return_const_ref() const& Point {
    var p: Point = Point{x: 3, y: 4}
    return const& p  //> [E3003]
}

func main() void { }
