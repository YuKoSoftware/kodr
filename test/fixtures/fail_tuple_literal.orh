module fixture

#version = (1, 0, 0)
#build   = exe

import std::bitfield

// ── Case 1: @tuple outside call context ───────────────

func stray() void {
    const _x = @tuple(1, 2)
    _ = _x
}

// ── Case 2: mixing positional and named elements ──────

func main() void {
    const _Flags: type = bitfield.Bitfield(u32, @tuple("Read", count: 2))
    stray()
}
