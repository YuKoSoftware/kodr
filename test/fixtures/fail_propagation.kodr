module main

#name    = "fail_propagation"
#version = Version(1, 0, 0)
#build   = exe
#bitsize = 32

func may_fail(n: i32) (Error | i32) {
    if(n == 0) {
        return Error("bad")
    }
    return n
}

// unhandled error union — void return can't propagate

func unhandled_error() void {
    const result = may_fail(1)
    if(result is Error) {
    }
}

func main() void { }
