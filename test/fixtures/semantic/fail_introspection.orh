module fixture


struct Point {
    x: f32
    y: f32
}

func main() void {
    // Wrong arg count — should fail with "@hasField takes exactly 2 arguments"
    const a: bool = @hasField(Point)  //> [E2058]
    // Non-string second arg — should fail with "@hasField requires a string literal"
    const b: bool = @hasField(Point, 42)  //> [E2059]
    // Unsupported operators — should fail with "@wrap only supports +, -, * operators"
    const c: i32 = @wrap(10 / 3)  //> [E2060]
    const d: i32 = @sat(10 % 3)  //> [E2060]
}
