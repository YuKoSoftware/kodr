module snap_basics

// const declarations
const MAX_COUNT: i32 = 100
const APP_NAME: String = "orhon"

// var declaration with assignment
var counter: i32 = 0

// type alias
const Speed: type = i32

// public function with parameters and return
pub func add(a: i32, b: i32) i32 {
    return a + b
}

// public function returning String
pub func greet(name: String) String {
    return "hello" ++ " " ++ name
}

// compt function — generates inline fn
pub compt func doubled(n: i32) i32 {
    return n * 2
}
