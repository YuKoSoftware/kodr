root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

[*.zig]
indent_style = space
indent_size = 4

[*.orh]
indent_style = space
indent_size = 4

[*.sh]
indent_style = space
indent_size = 4

[*.md]
indent_style = space
indent_size = 4
trim_trailing_whitespace = false

[*.json]
indent_style = space
indent_size = 2

[*.peg]
indent_style = space
indent_size = 4

[Makefile]
indent_style = tab

[{build.zig,build.zig.zon}]
indent_style = space
indent_size = 4
